{
    "name": "totocsa01/laravel-composer-package-development",
    "version": "1.0.0",
    "description": "Setting up a Laravel application used for development.",
    "license": "MIT",
    "minimum-stability": "dev",
    "authors": [
        {
            "name": "Csaba Tóth",
            "email": "totocsa01@gmail.com"
        }
    ],
    "type": "library",
    "autoload": {
        "psr-4": {
            "Totocsa01\\ComposerPackageDevelopment\\": "./"
        }
    },
    "require": {
        "php": "^7.4|^8.0",
        "laravel/framework": "^10.0|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Totocsa01\\ComposerPackageDevelopment\\ComposerPackageDevelopmentServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "name":"totocsa01-laravel-composer-package-development",
            "type": "path",
            "url": "totocsa01/laravel-composer-package-development",
            "options": {
                "symlink": true
            }
        }
    ]
}
